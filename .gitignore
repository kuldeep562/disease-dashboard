# ══════════════════════════════════════════════════════
#   Disease Dashboard — .gitignore
#   NEVER commit credentials, certs, or local configs
# ══════════════════════════════════════════════════════

# ── CREDENTIALS & SECRETS (CRITICAL — NEVER COMMIT) ──
.env
.env.*
!.env.example
backend/.env
backend/.env.*
*.secret
*_secret*
secrets.json
secrets.yaml

# ── SSL CERTIFICATES & KEYS (CRITICAL — NEVER COMMIT) ──
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
*.jks
certs/cert.pem
certs/key.pem
certs/*.pem
certs/*.key
certs/*.crt
# Keep the README in certs/
!certs/README.txt

# ── PYTHON ──────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
.venv/
env/
.env/
ENV/
env.bak/
venv.bak/
backend/venv/
backend/.venv/

# PyInstaller
*.manifest
*.spec

# Unit test / coverage
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
pytestdebug.log

# ── NODE / NPM (if any tools added later) ───────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
.npm
.yarn-integrity

# ── DATABASE ─────────────────────────────────────────
# Don't commit database dumps or exports
*.sql.gz
*.sql.bz2
*.dump
database_backup/
db_exports/
*.db
*.sqlite
*.sqlite3

# ── IDE & EDITOR ─────────────────────────────────────
# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example

# JetBrains (PyCharm, WebStorm, etc.)
.idea/
*.iml
*.iws
*.ipr
out/
.idea_modules/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~
.netrwhist

# Emacs
*#
.\#*

# ── OS GENERATED ─────────────────────────────────────
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.AppleDouble
.LSOverride
Icon

# Windows
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msm
*.msp
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ── LOGS ─────────────────────────────────────────────
logs/
*.log
*.log.*
log/
flask.log
gunicorn.log
access.log
error.log
npm-debug.log

# ── BUILD & DISTRIBUTION ─────────────────────────────
dist/
build/
*.zip
*.tar.gz
*.tar.bz2
*.tgz
release/

# ── TEMPORARY FILES ──────────────────────────────────
tmp/
temp/
.tmp/
*.tmp
*.temp
*.bak
*.orig
*.swp

# ── DOCKER (if added later) ──────────────────────────
.dockerenv
docker-compose.override.yml

# ── MISC ─────────────────────────────────────────────
.sass-cache/
.eslintcache
.stylelintcache
*.pid
*.seed
*.pid.lock
.grunt
.lock-wscript